---
import { relativePath } from '../utils/paths';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
}

const { title, description = '', ogImage = '/images/Background.jpeg', ogImageAlt, ogType = 'website' } = Astro.props;
const siteUrl = Astro.site ?? new URL('https://ariiellus.eth.limo');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const fullOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).toString();
const path = (target: string) => relativePath(Astro.url.pathname, target);
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Ariiellus" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Ariiellus" />
    <meta property="og:image" content={fullOgImage} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    <meta property="og:type" content={ogType} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content="@Ariiellus" />
    <meta name="twitter:image" content={fullOgImage} />

    <link rel="stylesheet" type="text/css" href={path('/css/main.css')} />
    <slot name="head" />
  </head>
  <body>
    <nav class="navbar">
      <div class="nav-links">
        <a href={path('/')} class="nav-link">Home</a>
        <a href={path('/general/portfolio/')} class="nav-link">Portfolio</a>
        <a href={path('/general/writings/')} class="nav-link">Writings</a>
        <div id="color-mode-switch">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
          </svg>
          <input type="checkbox" id="switch" />
          <label for="switch">Dark Mode Toggle</label>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
          </svg>
        </div>
      </div>
    </nav>

    <main class="container">
      <slot />
    </main>

    <script is:inline>
      (function() {
        const toggle = document.getElementById('switch');
        if (!toggle) return;
        const savedMode = localStorage.getItem('darkMode');
        if (savedMode === '1') toggle.checked = true;
        else if (savedMode === null && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
          toggle.checked = true;
          localStorage.setItem('darkMode', '1');
        }
        toggle.onchange = () => localStorage.setItem('darkMode', toggle.checked ? '1' : '0');
      })();
    </script>
  </body>
</html>
