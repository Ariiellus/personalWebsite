---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { relativePath } from '../../../utils/paths';

const path = (target: string) => relativePath(Astro.url.pathname, target);
---
<BaseLayout
  title="ESSAY_TITLE | Ariiellus"
  description="ESSAY_DESCRIPTION"
  ogType="article"
>
  <p><a href={path('/general/essays/')}>Back to essays</a></p>

  <h2>Title of the essay</h2>
  <p class="date">Date of the essay</p>
  <hr />
  <p>Content of the essay</p>
</BaseLayout>
