---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { relativePath } from '../../utils/paths';

const path = (target: string) => relativePath(Astro.url.pathname, target);
---
<BaseLayout
  title="Portfolio | Ariiellus"
  description="Portfolio of Ariiellus - Ethereum researcher, MEV analyst, and self-taught developer."
  ogUrl="https://ariiellus.eth.limo/general/portfolio/"
>
  <div class="section-header" style="margin-top: 3rem; margin-bottom: 2rem">
    <h2 style="margin-top: 0">Portfolio</h2>
    <div class="gradient-bar" style="width: 10rem"></div>
  </div>

  <div class="portfolio-grid">
    <section>
      <h3 style="border-bottom: 2px solid var(--color-divider); padding-bottom: 0.75rem; margin-bottom: 1.5rem;">Technical Expertise</h3>

      <div class="card work-item">
        <h4>🔐 Node Operator</h4>
        <p class="work-date">2022 - Present</p>
        <p class="work-description">
          Running nodes since 2022. Currently running nodes for EtherFi, a
          community validator for Ethereum Mexico and Meta Pool.
        </p>
      </div>

      <div class="card work-item">
        <h4>👨‍💻 Personal Projects</h4>
        <div class="project-border">
          <h5><a href="https://github.com/Ariiellus/2048Wars" target="_blank" rel="noopener noreferrer">2048Wars</a></h5>
          <p class="work-description">An onchain version of the classic 2048 game. I built this as part of a grant from BuidlGuidl.</p>
        </div>
        <div class="project-border">
          <h5><a href="https://github.com/Ariiellus/Sweeper-bot" target="_blank" rel="noopener noreferrer">Sweeper Bot Example</a></h5>
          <p class="work-description">Due my interest in MEV. I decided to build a bot that drains gas tokens to understand how it works. After building it, I help some friends to recover their funds.</p>
        </div>
      </div>

      <div class="card work-item">
        <h4>🏆 Hackathon Projects</h4>
        <div class="project-border">
          <h5><a href="https://github.com/Ariiellus/px402" target="_blank" rel="noopener noreferrer">px402</a><span class="text-muted">| ETHGlobal Buenos Aires 🏆</span></h5>
          <p class="work-description">An implementation for privacy payments using the x402 standard.</p>
        </div>
        <div class="project-border">
          <h5><a href="https://taikai.network/ethargentina/hackathons/tierra-de-buidlers-2025/projects/cmi6qw6us00bilzqrlnuxxfky/idea" target="_blank" rel="noopener noreferrer">Ramen Protocol</a><span class="text-muted">| Ethereum Argentina 🏆 🥇</span></h5>
          <p class="work-description">A Protocol that allows people to preserve cultural knowledge and pass them across generations. I contributed with the architecture design and zk implementation.</p>
        </div>
        <div class="project-border">
          <h5><a href="https://taikai.network/ethargentina/hackathons/tierra-de-buidlers-2025/projects/cmi6qw6us00bilzqrlnuxxfky/idea" target="_blank" rel="noopener noreferrer">TuCausa</a><span class="text-muted">| Aleph Crecimiento 🥇 Filecoin Track</span></h5>
          <p class="work-description">A fundraising platform that empowers communities to create and support local causes. I hacked solo, built contracts and the rest was vibecoded.</p>
        </div>
        <div class="project-border">
          <h5><a href="https://github.com/Ariiellus/Loanad" target="_blank" rel="noopener noreferrer">Loanad</a><span class="text-muted">| Mobil3 by Monad 🥈 Consumer Track</span></h5>
          <p class="work-description">A p2p lending protocol using crowdfunding loans. I built the contracts, integrate it with the frontend.</p>
        </div>
        <div class="project-border">
          <h5><a href="https://ethglobal.com/showcase/vibeflow-8hib4" target="_blank" rel="noopener noreferrer">VibeFlow</a><span class="text-muted">| ETHGlobal New York 🏆🏆</span></h5>
          <p class="work-description">A social networking platform designed to solve the adult friendship crisis. My first hackathon as a dev. I built the contracts and wallet integrations.</p>
        </div>
        <div class="project-border">
          <h5><a href="https://ethglobal.com/showcase/moderia-4pvy4" target="_blank" rel="noopener noreferrer">Moderia AI</a><span class="text-muted">| ETHGlobal Trifecta 🏆</span></h5>
          <p class="work-description">An AI agent that mediates digital deals between service providers and clients. I contributed with the repo and managing github branches.</p>
        </div>
        <div class="project-border">
          <h5><a href="https://ethglobal.com/showcase/metaintents-8kjr4" target="_blank" rel="noopener noreferrer">MetaIntents</a><span class="text-muted">| ETHGlobal Bangkok 🏆🏆🏆</span></h5>
          <p class="work-description">A module for smart wallets for default cross-chain transactions, utilizing multiple chains. In this hackathon, I contribute with research and building diagrams for the devs.</p>
        </div>
      </div>

      <div class="card work-item">
        <h4>⚡ Solidity Developer</h4>
        <p class="work-date">2023 - Present</p>
        <ul style="margin: 0; padding-left: 1.25rem">
          <li class="work-description">Advanced Foundry <em style="color: var(--color-anchor)">(in progress)</em> - Cyfrin Updraft</li>
          <li class="work-description">Speedrun Ethereum - BuidlGuidl</li>
          <li class="work-description">Foundry Fundamentals - Cyfrin Updraft</li>
          <li class="work-description">Web3 Wallet Security Basics - Cyfrin Updraft</li>
          <li class="work-description">Smart Contracts - Cyfrin Updraft</li>
        </ul>
      </div>

      <div class="card work-item">
        <h4>💻 Tech Stack</h4>
        <ul style="margin: 0; padding-left: 1.25rem">
          <li class="work-description">Solidity</li>
          <li class="work-description">TypeScript</li>
          <li class="work-description">Foundry</li>
          <li class="work-description">Git/GitHub</li>
        </ul>
      </div>
    </section>

    <section>
      <h3 style="border-bottom: 2px solid var(--color-divider); padding-bottom: 0.75rem; margin-bottom: 1.5rem;">Previous Work</h3>

      <div class="card work-item">
        <h4>Researcher & Host at Kairos Research</h4>
        <p class="work-date">2023 - Present</p>
        <p class="work-description">
          I host a <a href="https://x.com/Research_Kairos" target="_blank" rel="noopener noreferrer">weekly livestream</a>
          covering the latest news and developments in the crypto space. Our
          <a href="https://www.lupaweb3.kairosresearch.xyz/subscribe" target="_blank" rel="noopener noreferrer">newsletter</a>
          has reached +500 subscribers during the first year. Occasionally,
          <a href={path('/general/writings/')}>I write blogs</a> about MEV, DeFi and the Ethereum Roadmap.
        </p>
      </div>

      <div class="card work-item">
        <h4>Community Lead at Ethereum Mexico</h4>
        <p class="work-date">2022 - 2025</p>
        <p class="work-description">
          I cofounded <a href="https://x.com/Ethereum_mexico" target="_blank" rel="noopener noreferrer">Ethereum Mexico</a>
          and contributed as Community Lead and Finance Manager for almost three years. During this time I ran several scholarship programs,
          gave over 20 Ethereum-focused talks and workshops, and organized meetups across the country with two major events with an
          attendance of over 600 people.
        </p>
      </div>

      <div class="card work-item">
        <h4>Early days</h4>
        <p class="work-date">2020 - 2022</p>
        <p class="work-description">
          I joined to crypto after my best friend convinced me to learn trading, during my first two years I collaborated as translator in
          BanklessDAO and shortly after I joined to Cryptoversidad where I developed a course for newbies.
        </p>
      </div>

      <div class="card work-item">
        <h4>Mechanical Designer</h4>
        <p class="work-date">2018 - 2022</p>
        <p class="work-description">
          After graduating as Mechanical Engineer from Benemerita Universidad Autonoma de Puebla, I worked as a Mechanical Designer
          for several companies in the heat exchanger industry. I reduced 75% the production documentation process, improved airflow &
          piping designs through FEA & CFD analysis. During my experience at the University I mentored several students in CAD software like
          Catia, SolidWorks and Nastran.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
